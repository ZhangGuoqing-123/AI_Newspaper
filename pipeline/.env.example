# 复制这个文件为 .env，把占位符换成你的真实 key。
# .env 已被 .gitignore 忽略，绝不会提交进仓库。
# ⚠️ key 只放在这里，永远不要写进代码、聊天或截图。

# Kimi（Moonshot）—— 摘要 / 口播稿生成
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-0711-preview

# DeepSeek —— 选题 / 排序 / 质检等决策节点
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 硅基流动(SiliconFlow) —— 日报封面图生成（OpenAI 兼容，有免费额度）
# 注册：https://siliconflow.cn  →「API密钥」→ 复制 sk- 开头的 key
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=black-forest-labs/FLUX.1-schnell   # 免费模型，4步出图快

# TikHub —— 按关注账号爬 Twitter
TIKHUB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
TIKHUB_BASE_URL=https://api.tikhub.dev

# Supabase —— pipeline 写库用 service key（绕过 RLS）；前端另用 anon key 只读
SUPABASE_URL=https://你的项目.supabase.co
SUPABASE_SERVICE_KEY=你的_service_role_key
